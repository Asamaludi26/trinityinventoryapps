# ============================================
# Environment Variables untuk Production
# ============================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository!

# ============================================
# Database Configuration
# ============================================
# User database PostgreSQL
DB_USER=trinity_admin

# Password database (GENERATE dengan: openssl rand -base64 32)
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# Nama database
DB_NAME=trinity_asset

# Connection string untuk Prisma (format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA)
# Host 'db' merujuk pada nama service di docker-compose.yml
DATABASE_URL=postgresql://trinity_admin:CHANGE_THIS_TO_STRONG_PASSWORD@db:5432/trinity_asset?schema=public

# ============================================
# Application Security
# ============================================
# JWT Secret (GENERATE dengan: openssl rand -base64 64)
# HARUS sangat panjang dan acak untuk keamanan
JWT_SECRET=CHANGE_THIS_TO_VERY_LONG_RANDOM_STRING_MIN_64_CHARACTERS

# Durasi token akses (format: 1h, 12h, 7d, dll)
JWT_EXPIRATION=12h

# Durasi refresh token
JWT_REFRESH_EXPIRATION=7d

# Port untuk Backend API (internal Docker, tidak perlu diubah)
PORT=3001

# Node Environment
NODE_ENV=production

# ============================================
# Frontend Configuration
# ============================================
# URL API untuk frontend (ganti dengan domain production Anda)
VITE_API_URL=https://aset.trinitymedia.co.id/api

# Gunakan Mock API? (false untuk production)
VITE_USE_MOCK=false

# ============================================
# Domain Configuration
# ============================================
# Domain aplikasi (untuk SSL certificate dan CORS)
DOMAIN=aset.trinitymedia.co.id

# ============================================
# WhatsApp Integration (Opsional)
# ============================================
# URL API WhatsApp Gateway
WA_API_URL=https://api.watzap.id/v1

# API Key dari provider WhatsApp
WA_API_KEY=your_whatsapp_api_key_here

# ID Grup WhatsApp untuk Notifikasi
WA_GROUP_LOGISTIC_ID=1203630239482@g.us
WA_GROUP_PURCHASE_ID=1203630291823@g.us
WA_GROUP_MANAGEMENT_ID=1203630239123@g.us

# ============================================
# Email Configuration (Opsional - untuk notifikasi)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@trinitymedia.co.id

# ============================================
# Logging Configuration (Opsional)
# ============================================
# LOG_LEVEL=info
# LOG_FORMAT=json

# ============================================
# Backup Configuration (Opsional)
# ============================================
# BACKUP_RETENTION_DAYS=7
# BACKUP_S3_BUCKET=trinity-db-backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

