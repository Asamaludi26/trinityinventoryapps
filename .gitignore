# ============================================
# Trinity Inventory Apps - Comprehensive .gitignore
# Production-ready gitignore for monorepo
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ============================================
# Build Outputs
# ============================================
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.vite/
*.tsbuildinfo

# Frontend build
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.next/

# Backend build
backend/dist/
backend/build/

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log.*

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# PostgreSQL
*.sql.gz
*.sql.backup
*.dump
pgdata/
postgres-data/
data/

# Prisma
backend/prisma/migrations/*.sql
!backend/prisma/migrations/migration_lock.toml

# ============================================
# Docker
# ============================================
.docker/
docker-compose.override.yml
*.dockerignore.local

# Docker volumes
volumes/
pgdata/
mysql-data/
redis-data/

# ============================================
# IDE & Editors
# ============================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================
# OS Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

