.local/
.localenv

# Secrets & Keys
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
.secrets/

# SSL Certificates (except examples)
*.pem
*.key
!*.example.pem
!*.example.key

# Application specific
uploads/
temp/
tmp/
storage/
public/uploads/
public/storage/

# ============================================
# Production Specific
# ============================================
# Backup files
backups/
*.backup
*.sql.gz
*.dump

# Log files
logs/
*.log
*.log.*

# Database dumps
*.sql
!schema.sql
!seed.sql

